{
  "config": {
    "progress": {
      "link": "Press the Auth or Service button on your PoolSync device at {ip_address} to complete local linking.\n\nThe integration is waiting for the device to return its access password. This attempt will time out after about {time_remaining} seconds."
    },
    "step": {
      "user": {
        "title": "PoolSync Setup: Connect to Device",
        "description": "Enter the local IP address of your AutoPilot PoolSync device.",
        "data": {
          "ip_address": "IP Address"
        }
      },
      "reauth_confirm": {
        "title": "PoolSync Reauthenticate Device",
        "description": "Press Submit to start local relinking for the PoolSync device at {ip_address}. Then press the Auth or Service button on the physical device to complete reauthentication."
      },
      "link_failed": {
        "title": "PoolSync Setup: Link Device",
        "description": "The PoolSync device at {ip_address} did not finish linking. Select Submit to retry the push-link process.\n\nIf this keeps failing, restart the PoolSync device and try again."
      }
    },
    "error": {
      "cannot_connect": "Failed to connect to the PoolSync device at the specified IP address. Please check the IP address and ensure the device is powered on and connected to the network.",
